{
	"compatibility_date": "2025-10-08",
	"main": "src/worker.ts",
	"name": "nz-electricity-stats-api",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": [
			"*/2 * * * *",
			"0 12 * * *",
			"02 * * * *"
		]
