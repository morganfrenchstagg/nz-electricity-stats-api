			"bucket_name": "dispatch",
			"binding": "dispatch"
		},
		{
			"bucket_name": "offers",
			"binding": "offers"
		}
	],
	"kv_namespaces": [
		{
			"binding": "dispatch_kv",
			"id": "37b0648936874b0c831d9fbae41abc3b"
		}
	],
	"limits": {
		"cpu_ms": 300000
	}
}